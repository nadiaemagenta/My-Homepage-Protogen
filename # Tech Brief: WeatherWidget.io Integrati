## Phase 4: Dynamic Location (Optional - 30 minutes)

### Step 9: User Location Detection
Add JavaScript to dynamically set location:

```html
<div id="user-weather-widget">
    <div class="weather-loading">
        <p>🌍 Detecting your location...</p>
    </div>
</div>

<script>
function initUserLocationWeather() {
    const container = document.getElementById('user-weather-widget');
    
    if (navigator.geolocation) {
        navigator.geolocation.getCurrentPosition(
            function(position) {
                const lat = position.coords.latitude.toFixed(2);
                const lon = position.coords.longitude.toFixed(2);
                
                // Create weather widget with user's coordinates
                container.innerHTML = `
                    <a class="weatherwidget-io" 
                       href="https://forecast7.com/en/${lat}d${lon.replace('-', 'n').replace('.', 'd')}/your-location/" 
                       data-label_1="YOUR LOCATION" 
                       data-label_2="CURRENT WEATHER" 
                       data-theme="original">
                       Your Location Weather
                    </a>
                `;
                
                // Reinitialize the weather widget script
                if (window.weatherwidget && window.weatherwidget.load) {
                    window.weatherwidget.load();
                }
            },
            function(error) {
                // Fallback to default location
                container.innerHTML = `
                    <a class="weatherwidget-io" 
                       href="https://forecast7.com/en/47d61n122d33/seattle/" 
                       data-label_1="SEATTLE" 
                       data-label_2="DEFAULT LOCATION" 
                       data-theme="original">
                       Seattle Weather
                    </a>
                `;
                
                if (window.weatherwidget && window.weatherwidget.load) {
                    window.weatherwidget.load();
                }
            }
        );
    } else {
        // Browser doesn't support geolocation
        container.innerHTML = `
            <a class="weatherwidget-io" 
               href="https://forecast7.com/en/47d61n122d33/seattle/" 
               data-label_1="SEATTLE" 
               data-label_2="WEATHER" 
               data-theme="original">
               Seattle Weather
            </a>
        `;
    }
}

// Initialize after the main weather widget script loads
document.addEventListener('DOMContentLoaded', function() {
    // Wait a bit for the weather widget script to load
    setTimeout(initUserLocationWeather, 1000);
});
</script>
```

